MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Talk_Stage02_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 7ea6260e28ce9a84b96efd9508de4ab7, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 7023507325818222534
    m_Localized: Well, hello there.
    m_Metadata:
      m_Items: []
  - m_Id: 2601454763290002037
    m_Localized: Who are you?!
    m_Metadata:
      m_Items: []
  - m_Id: 2718966408865626873
    m_Localized: Where am I?
    m_Metadata:
      m_Items: []
  - m_Id: 5373019814136094439
    m_Localized: Isn't it obvious? I'm Vanilla, the artist! Yes, indeed!
    m_Metadata:
      m_Items: []
  - m_Id: 909650436601845691
    m_Localized: (Obvious...?)
    m_Metadata:
      m_Items: []
  - m_Id: 5454960842673800993
    m_Localized: That's the face of someone with questions.
    m_Metadata:
      m_Items: []
  - m_Id: 5984980547864081358
    m_Localized: This is my atelier!
    m_Metadata:
      m_Items:
      - rid: 1662523297361821947
  - m_Id: 5980476459379056637
    m_Localized: (So this is where I am.)
    m_Metadata:
      m_Items: []
  - m_Id: 2172371201322117035
    m_Localized: 'I capture decisive moments,

      turn them into paintings, and
      put them on display!'
    m_Metadata:
      m_Items: []
  - m_Id: 8043203444997937572
    m_Localized: And the most decisive moment of all is the moment of failure!
    m_Metadata:
      m_Items: []
  - m_Id: 1467704674993580532
    m_Localized: (Yikes... she's just a sadist in an artist's smock.)
    m_Metadata:
      m_Items: []
  - m_Id: 2430958611684600880
    m_Localized: Now then... next, you're going to...
    m_Metadata:
      m_Items: []
  - m_Id: 5671947248032641168
    m_Localized: fall off that cliff, bomb and all.
    m_Metadata:
      m_Items: []
  - m_Id: 8435271925346515024
    m_Localized: "And when you hit the ground\u2014boom! Blown to bits."
    m_Metadata:
      m_Items: []
  - m_Id: 3219132831518115693
    m_Localized: (I was wrong! She's a kind person warning me about danger!)
    m_Metadata:
      m_Items: []
  - m_Id: 3047065892418175488
    m_Localized: Listen carefully. For the sake of my inspiration,
    m_Metadata:
      m_Items: []
  - m_Id: 53327721388112366
    m_Localized: I need you to die in a glorious explosion, exactly as I predicted!
    m_Metadata:
      m_Items: []
  - m_Id: 1165803043213401772
    m_Localized: (I was wrong again! She's definitely just insane!)
    m_Metadata:
      m_Items: []
  - m_Id: 4560365996716796641
    m_Localized: Whatever you do, do NOT take that Shortbread Cushion beside me,
    m_Metadata:
      m_Items:
      - rid: 1662523297361821948
  - m_Id: 6469717889889887019
    m_Localized: carry it with you, and try to land on it!
    m_Metadata:
      m_Items: []
  - m_Id: 3468308238743827537
    m_Localized: Surviving because it softened your fall would be an insult to my
      art!
    m_Metadata:
      m_Items: []
  - m_Id: 4901086709209057190
    m_Localized: '(Got it! If I take that cushion, jump off the cliff,

      and
      land on it, I won''t explode.)'
    m_Metadata:
      m_Items: []
  - m_Id: 1687582271732652562
    m_Localized: Thanks! I'll keep that in mind!
    m_Metadata:
      m_Items: []
  - m_Id: 1486718284932755562
    m_Localized: Excellent! Every living thing is an artist.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds:
    - rid: 1662523297361821947
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "atelier \u306F\u5C11\u3057\u6C17\u53D6\u3063\u305F\u82B8\u8853\u5BB6\u3063\u307D\u3044\u8A9E\u3002\u81EA\u7136\u3055\u512A\u5148\u306A\u3089
          studio \u306B\u5909\u66F4\u53EF\u3002"
    - rid: 1662523297361821948
      type: {class: Comment, ns: UnityEngine.Localization.Metadata, asm: Unity.Localization}
      data:
        m_CommentText: "\u300C\u30B5\u30D6\u30EC\u30AF\u30C3\u30B7\u30E7\u30F3\u300D\u306F\u82F1\u8A9E\u3067\u306F
