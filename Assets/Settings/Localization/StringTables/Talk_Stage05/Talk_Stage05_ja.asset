  - m_Id: 28715741202
    m_Localized: "\u7981\u3058\u3089\u308C\u3066\u306A\u304B\u3063\u305F\u3089\uFF1F"
    m_Metadata:
      m_Items: []
  - m_Id: 28715741203
    m_Localized: "\u305D\u306E\u5834\u5408\u3001\u541B\u306F\u3082\u3046\u9003\u3052\u3066\u3044\u308B\u3079\u304D\u3060\u306D\u3002"
