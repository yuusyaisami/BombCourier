    m_Metadata:
      m_Items: []
  - m_Id: 28715741186
    m_Localized: "\u6B21\u306E\u533A\u753B\u306A\u3089\u3001\u3042\u306E\u30B2\u30FC\u30C8\u3060\u3002\u6BB5\u30DC\u30FC\u30EB\u3067\u585E\u304C\u3063\u3066\u3044\u308B\u3002"
