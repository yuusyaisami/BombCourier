      m_Items: []
  - m_Id: 190110000026
    m_Localized: "\u591A\u304F\u306E\u4EBA\u3092\u5371\u967A\u306B\u3055\u3089\u3059\u304B\u3082\u3057\u308C\u306A\u3044\u3057\u3001"
