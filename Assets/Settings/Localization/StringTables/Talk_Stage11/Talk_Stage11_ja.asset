  m_TableData:
  - m_Id: 190110000000
    m_Localized: "\u541B\u304C\u3079\u305F\u3079\u305F\u7206\u5F3E\u3092\u89E6\u3063\u3066\u304F\u308C\u308B\u304A\u304B\u3052\u3067\u3001"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000001
    m_Localized: "\u5371\u967A\u7269\u304C\u5C11\u306A\u304F\u3066\u3001\u3042\u308A\u304C\u305F\u3044\u3088"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000002
    m_Localized: "\u3057\u304B\u3057\u3001\u3069\u3046\u3057\u3066\u3001\u305D\u3093\u306A\u306B\u3082\u3001
      \u5916\u306B\u3053\u3060\u308F\u3063\u3066\u308B\u3093\u3060\u3044"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000003
    m_Localized: "\u5916\u3092\u77E5\u3063\u3066\u308B\u304B\u3089?"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000004
    m_Localized: "\u306A\u308B\u307B\u3069\u3001"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000005
    m_Localized: "\u541B\u304C\u3001\u5916\u306E\u3053\u3068\u3092\u8A71\u3059\u305F\u3073\u306B\u3001
      \u50D5\u3082\u305D\u306E\u4E16\u754C\u306B\u9B45\u4E86\u3055\u308C\u3066\u3044\u304F\u6C17\u304C\u3059\u308B\u3093\u3060"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000006
    m_Localized: "\u3060\u304B\u3089\u3001\u3044\u308D\u3044\u308D\u8ABF\u3079\u3061\u3083\u3063\u305F"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000007
    m_Localized: "\u3069\u3046\u3084\u3089\u3001\u3042\u308B\u533A\u753B\u306B\u3001\u9AD8\u3044\u30BF\u30EF\u30FC\u304C\u3042\u308B\u3088\u3046\u3067\u3001"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000008
    m_Localized: "\u305D\u306E\u30BF\u30EF\u30FC\u306E\u9802\u4E0A\u306B\u884C\u304F\u306E\u304C\u3001\u6700\u5927\u306E\u30BF\u30D6\u30FC\u306B\u306A\u3063\u3066\u308B\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000009
    m_Localized: "\u306A\u3093\u3067\u305D\u306E\u30BF\u30EF\u30FC\u304C\u30BF\u30D6\u30FC\u306A\u306E\uFF1F"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000010
    m_Localized: "\u30E4\u30AF\u30E2\u541B\u3001\u3067\u306F\u541B\u306B\u8ABF\u67FB\u306E\u4F9D\u983C\u3092\u3057\u3088\u3046\uFF01"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000011
    m_Localized: "\u305D\u3046\u3060\u306A... \u79D1\u5B66\u7684\u306B\u306F\u308F\u304B\u3089\u306A\u3044\u3051\u3069\u3001"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000012
    m_Localized: "\u306A\u3093\u304B\u540D\u524D\u3092\u51FA\u3059\u306E\u3082\u3084\u3070\u3044\u5834\u6240\uFF1F
      \u305D\u3093\u306A\u98A8\u306B\u8A00\u308F\u308C\u3066\u308B\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000013
    m_Localized: "\u3058\u3083\u3042\u3001\u305D\u3053\u3060\uFF01 \u305D\u3053\u306B\u4F55\u304B\u3042\u308B"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000014
    m_Localized: "\u3053\u3053\u306B\u884C\u304F\u306E\u306F\u3001\u3044\u308F\u3070\u3001
      \u795E\u8056\u306A\u7981\u8DB3\u5730\u306B\u571F\u8DB3\u3067\u8E0F\u307F\u8FBC\u3080\u884C\u70BA\u306B\u8FD1\u3044"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000015
    m_Localized: "\u79D1\u5B66\u8005\u306A\u306E\u306B\u3001 \u975E\u73FE\u5B9F\u7684\u306A\u3053\u3068\u3092\u4FE1\u3058\u308B\u306E\uFF1F"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000016
    m_Localized: "\u305D\u308C\u304C\u73FE\u5B9F\u306A\u306E\u304B\u3001\u975E\u73FE\u5B9F\u306A\u306E\u304B"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000017
    m_Localized: "\u3082\u306F\u3084\u50D5\u306B\u306F\u308F\u304B\u3089\u306A\u3044\u3093\u3060\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000018
    m_Localized: "\u304A\u3044\u304A\u3044\uFF01 \u7262\u5C4B\u306B\u9589\u3058\u8FBC\u3081\u3089\u308C\u308D\u3063\u3066\u8A00\u3044\u305F\u3044\u306E\u304B\uFF1F"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000019
    m_Localized: "\u3070\u308C\u306A\u304D\u3083\u3044\u3044\u3051\u3069\u3001 \u3070\u308C\u305F\u3089\u3001\u5C45\u5834\u6240\u306F\u306A\u3044\u3093\u3060\u305E"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000020
    m_Localized: "\u305D\u306E\u6642\u306F\u653E\u6D6A\u8005\u306B\u3067\u3082\u306A\u308C\u3070\u3044\u3044\u3058\u3083\u306A\u3044\u304B"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000021
    m_Localized: "\u7C21\u5358\u306B\u8A00\u3063\u3066\u304F\u308C\u308B\u3088"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000022
    m_Localized: "\u306A\u3093\u3067\u6559\u3048\u3066\u304F\u308C\u308B\u306E\uFF1F"
    m_Metadata:
      m_Items: []
  - m_Id: 190110000023
