    m_Localized: "\u3053\u308C\u3067\u3042\u306A\u305F\u306F\u3001 \u4EBA\u985E\u521D\u306E\u300C\u4E8C\u8DB3\u6B69\u884C\u30B8\u30E3\u30F3\u30D7\u77E5\u80FD\u30CD\u30BA\u30DF\u300D\u3078\u3068\u9032\u5316\u3057\u307E\u3057\u305F\uFF01"
