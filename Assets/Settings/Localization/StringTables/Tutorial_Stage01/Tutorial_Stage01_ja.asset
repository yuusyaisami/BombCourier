  - m_Id: 32486420505
    m_Localized: "\u77ED\u62BC\u3057\u3067Reload(\u7206\u5F3E\u524D\u3078), \u9577\u62BC\u3057\u3067Reset(\u30B9\u30C6\u30FC\u30B8\u6700\u521D\u304B\u3089)\u3068\u306A\u308A\u307E\u3059\u3002"
