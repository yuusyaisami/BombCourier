    m_Localized: "\u3057\u304B\u3057\u3001\u7206\u5F3E\u306E\u53D6\u308A\u6271\u3044\u306B\u306F\u6CE8\u610F\u304C\u5FC5\u8981\u3067\u3059\u3002"
