      m_Items: []
  - m_Id: 32486420503
    m_Localized: "\u4F59\u88D5\u304C\u3042\u308C\u3070\u3001\u70B9\u706B\u4E2D\u306B\u300C\u661F\u578B\u306E\u30AA\u30D6\u30B8\u30A7\u30AF\u30C8\u300D\u306B\u89E6\u308C\u3066\u30DC\u30FC\u30CA\u30B9\u3092\u72D9\u3044\u307E\u3057\u3087\u3046\u3002"
