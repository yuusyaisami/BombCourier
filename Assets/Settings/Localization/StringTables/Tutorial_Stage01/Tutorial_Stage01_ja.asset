  - m_Id: 32486420490
    m_Localized: "\u6B74\u53F2\u306B\u6B8B\u308B\u5049\u696D\u3067\u3059\u3002 \u7D20\u6674\u3089\u3057\u3044\u5B9F\u9A13\u7D50\u679C\u3092\u3042\u308A\u304C\u3068\u3046\u3054\u3056\u3044\u307E\u3059\uFF01"
