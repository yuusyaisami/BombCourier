    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030649004972].talkRequestData.dialogueText
      value: "\u3053\u306E\u4E16\u754C\u306B\u306F\u5A2F\u697D\u3063\u3066\u3084\u3064\u304C\u307B\u307C\u7121\u3044\u306E\u304C\u539F\u56E0\u3060\u304B\u3089\u3002"
