    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030649004785].talkRequestData.dialogueText
      value: "\u307E\u3042\u3044\u3044\u3055\u3002\u50D5\u304C\u3053\u3093\u306A\u306B\u6839\u3092\u8A70\u3081\u308B\u306E\u3082\u3001"
