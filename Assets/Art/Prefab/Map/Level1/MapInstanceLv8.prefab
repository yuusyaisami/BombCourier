    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030353043593].talkRequestData.dialogueText
      value: "\u6700\u8FD1\u77E5\u3063\u305F\u3093\u3060\u3051\u3069\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030353043966].talkRequestData.dialogueText
      value: "\u3069\u3063\u304B\u306E\u533A\u753B\u306B\u306F\u56DB\u5B63\u3063\u3066\u3084\u3064\u304C\u3042\u308B\u3089\u3057\u3044\u3088"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030353044246].talkRequestData.dialogueText
      value: "\u767D\u3044\u7DBF\u304C\u964D\u3063\u3066\u304F\u308B\u6642\u671F\u304C\u3042\u308B\u3089\u3057\u3044"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030367723659].talkRequestData.dialogueText
      value: "\u89E6\u308B\u3068\u51B7\u305F\u3044\u3093\u3060\u3063\u3066\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030367724032].talkRequestData.dialogueText
      value: "\u304B\u3068\u601D\u3046\u3068\u4ECA\u5EA6\u306F\u3001\n\u767D\u3044\u82B1\u3073\u3089\u304C\u821E\u3044\u6563\u308B\u6642\u671F\u304C\u6765\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030367724312].talkRequestData.dialogueText
      value: "\u305D\u306E\u6642\u671F\u306B\u898B\u308B\u77ED\u304F\u3066\u306F\u304B\u306A\u3044\u5922\u306E\u3053\u3068\u3092\u3001\n\u6625\u5922\u3063\u3066\u547C\u3076\u3089\u3057\u3044\u3093\u3060\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030367724499].talkRequestData.dialogueText
      value: "\u3053\u3053\u306B\u6765\u308B\u524D\u3001\n\u50D5\u3082\u4F3C\u305F\u3088\u3046\u306A\u666F\u8272\u3092\u898B\u305F\u6C17\u304C\u3059\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030382665963].talkRequestData.dialogueText
      value: "\u8D64\u3044\u8449\u3063\u3071\u304C\u3001\u821E\u3044\u6563\u308B\u666F\u8272\u3060\u3063\u305F\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030382666243].talkRequestData.dialogueText
      value: "\u5916\u3067\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030382666616].talkRequestData.dialogueText
      value: "\u5916"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030411239475].talkRequestData.dialogueText
      value: '?'
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030411239662].talkRequestData.dialogueText
      value: "\u306F\u3042, \u524D\u306B\u3082\u8A00\u3063\u305F\u3051\u3069\u3001\n\u305D\u308C\u3042\u3093\u307E\u308A\u53E3\u306B\u3057\u306A\u3044\u3067\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030411239849].talkRequestData.dialogueText
      value: "\u3067\u3082\u3001\u541B\u304C\u898B\u305F\u3053\u3068\u304C\u3042\u308B\u3063\u3066\u3044\u3046\u306A\u3089\u3001\n\u304D\u3063\u3068\u56DB\u5B63\u306F\u3042\u308B\u3093\u3060\u306D\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030411240409].talkRequestData.dialogueText
      value: "\u795E\u96A0\u3057\u307F\u305F\u3044\u306A\u3082\u306E\u3058\u3083\u306A\u3044\u304B\u306A\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030429327508].talkRequestData.dialogueText
      value: "\u3067\u3082\u3001\u50D5\u3082\u4E00\u5FDC\u306F\u79D1\u5B66\u8005\u3060\u304B\u3089\u306D\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030429327695].talkRequestData.dialogueText
      value: "\u795E\u96A0\u3057\u3068\u304B\u3001\u305D\u3082\u305D\u3082\u795E\u306E\u5B58\u5728\u3082\u4FE1\u3058\u3066\u306F\u306A\u3044\u3088"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030429327882].talkRequestData.dialogueText
      value: "\u307B\u3089\u3001\u6843\u6E90\u90F7(\u98DF\u3079\u7269\u304C\u3042\u308B\u5834\u6240)\u306E\u533A\u753B\u3063\u3066\u3001\n\u982D\u4E0A\u306B\u5927\u304D\u306A\u7A74\u304C\u958B\u3044\u3066\u308B\u3060\u308D\u3046\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030429328069].talkRequestData.dialogueText
      value: "\u3042\u306E\u5148\u306B\u795E\u69D8\u304C\u3044\u308B\u3063\u3066\u805E\u3044\u3066\u3044\u305F\u304B\u3089\u3001\n\u898B\u306B\u884C\u3053\u3046\u3068\u601D\u3063\u305F\u3093\u3060"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030429328256].talkRequestData.dialogueText
      value: "\u5916\u304C\u898B\u3048\u305F\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030449250363].talkRequestData.dialogueText
      value: "\u307E\u3055\u304B\u3002\u9014\u4E2D\u306B\u898B\u3048\u306A\u3044\u30AC\u30E9\u30B9\u307F\u305F\u3044\u306A\u3082\u306E\u304C\u5F35\u3063\u3066\u3042\u3063\u3066\u3001\n\u51FA\u3089\u308C\u306A\u304B\u3063\u305F\u3088\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030449250550].talkRequestData.dialogueText
      value: "\u30AC\u30E9\u30B9\u306F\u5B9F\u969B\u306B\u306F\u3001\u305D\u306E\u5965\u3092\u5199\u3055\u306A\u3044\u3082\u306E\u3082\u3042\u308B\u3093\u3060\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030449250737].talkRequestData.dialogueText
      value: "\u304D\u3063\u3068\u305D\u308C\u3060\u308D\u3046\u306D\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030449251110].talkRequestData.dialogueText
      value: "\u50D5\u306F\u4E3B\u306B\u3001\n\u3053\u306E\u4E16\u754C\u306E\u898F\u5247\u6027\u3092\u3001\u89B3\u5BDF\u3057\u3066\u767A\u898B\u3059\u308B\u3053\u3068\u3092\u3057\u3066\u308B\u3093\u3060\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030449251297].talkRequestData.dialogueText
      value: "\u6843\u6E90\u90F7\u306E\u98DF\u3079\u7269\u304C\u3001\u3069\u306E\u304F\u3089\u3044\u306E\u9593\u9694\u3067\u51FA\u3066\u304F\u308B\u306E\u304B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030473105564].talkRequestData.dialogueText
      value: "\u7206\u5F3E\u304C\u6D88\u3048\u3066\u304B\u3089\u3001\u540C\u3058\u5834\u6240\u306B\u623B\u308B\u307E\u3067\u4F55\u62CD\u304B\u304B\u308B\u306E\u304B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030473105751].talkRequestData.dialogueText
      value: "\u306A\u3093\u3060\u304B\u5730\u5473\u3060\u306D\u3002\u305D\u308C\u304C\u4F55\u306E\u5F79\u306B\u7ACB\u3064\u306E\uFF1F "
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030473106031].talkRequestData.dialogueText
      value: "\u5730\u5473\u306A\u3082\u306E\u307B\u3069\u3001\u610F\u5916\u3068\u5F79\u306B\u7ACB\u3064\u3093\u3060\u3088\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030473106218].talkRequestData.dialogueText
      value: "\u4F8B\u3048\u3070\u3001\u98DF\u3079\u7269\u304C\u51FA\u308B\u6642\u9593\u304C\u5206\u304B\u308C\u3070\u3001\u4E26\u3076\u6642\u9593\u3092\u6C7A\u3081\u3089\u308C\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030473106405].talkRequestData.dialogueText
      value: "\u7206\u5F3E\u304C\u623B\u308B\u6642\u9593\u304C\u5206\u304B\u308C\u3070\u3001\u8FD1\u3065\u304B\u306A\u3044\u6642\u9593\u3092\u6C7A\u3081\u3089\u308C\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030486999200].talkRequestData.dialogueText
      value: "\u3061\u306A\u307F\u306B\u4F9B\u7D66\u306E\u30BF\u30A4\u30DF\u30F3\u30B0\u306F\u5B9F\u306F\u56FA\u5B9A\u306A\u3093\u3060\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030486999387].talkRequestData.dialogueText
      value: "\u5927\u4F53\u50D5\u305F\u3061\u304C\u7A7A\u8179\u306B\u306A\u308B\u3050\u3089\u3044\u306E\u30BF\u30A4\u30DF\u30F3\u30B0"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030486999574].talkRequestData.dialogueText
      value: "\u3078\u3048\u3001\u90FD\u5408\u3088\u304F\u3067\u304D\u3066\u308B\u306D\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030486999854].talkRequestData.dialogueText
      value: "\u57FA\u672C\u7684\u306B\u7814\u7A76\u5185\u5BB9\u306F\u4E0A\u304B\u3089\u6C7A\u3081\u3089\u308C\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030487000041].talkRequestData.dialogueText
      value: "\u8ABF\u3079\u308B\u3053\u3068\u3092\u6C7A\u3081\u308B\u8005\u304C\u3044\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030504038564].talkRequestData.dialogueText
      value: "\u8ABF\u3079\u308B\u8005\u304C\u3044\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030504038751].talkRequestData.dialogueText
      value: "\u4F7F\u3046\u8005\u304C\u3044\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030504038938].talkRequestData.dialogueText
      value: "\u50D5\u306F\u771F\u3093\u4E2D\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030504039125].talkRequestData.dialogueText
      value: "\u8AB0\u3082\u77E5\u3089\u306A\u3044\u3053\u3068\u3092\u8ABF\u3079\u3066\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030504039312].talkRequestData.dialogueText
      value: "\u7D50\u679C\u7684\u306B\u8AB0\u304B\u306B\u611F\u8B1D\u3055\u308C\u308B"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030517669963].talkRequestData.dialogueText
      value: "\u305D\u308C\u304C\u4F55\u3060\u304B\u751F\u304D\u3066\u308B\u3063\u3066\u611F\u3058\u304C\u3057\u3066\u697D\u3057\u3044\u3093\u3060\u3088\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030517670150].talkRequestData.dialogueText
      value: "\u8A71\u304C\u9577\u3044\u3088...\n\u3067\u3082\u697D\u3057\u3044\u306E\u306F\u3044\u3044\u3053\u3068\u3060\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030517670523].talkRequestData.dialogueText
      value: "\u3068\u3053\u308D\u3067\u3001\u541B\u306E\u8A71\u3092\u805E\u3044\u3066\u308B\u3068\u3001\u5C11\u3057\u9055\u548C\u611F\u3092\u899A\u3048\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030517670710].talkRequestData.dialogueText
      value: "\u3053\u3053\u306B\u6765\u308B\u524D\u306B\u3044\u305F\u5834\u6240\u304C\u3042\u308B\u307F\u305F\u3044\u306A\u8A00\u3044\u65B9\u3060\u3063\u305F\u3088\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030517670897].talkRequestData.dialogueText
      value: "\u3082\u3057\u305D\u3046\u306A\u3089\u3001\u541B\u306E\u5B58\u5728\u305D\u306E\u3082\u306E\u304C\u3001\n\u5916\u306E\u5B58\u5728\u3092\u8A3C\u660E\u3057\u3066\u308B\u3063\u3066\u3053\u3068\u3060\u308D\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030538903817].talkRequestData.dialogueText
      value: "\u3063\u3066\u3053\u3068\u306F...\u3048\u3063\u3068\u3001\u541B\u306F\u795E\u69D8\u306A\u306E\u304B?"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030538904563].talkRequestData.dialogueText
      value: "\u5618\u3060\u308D\uFF01\u30CD\u30BA\u30DF\u304C\u795E\u69D8\u3060\u3063\u305F\u306A\u3093\u3066\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030561448110].talkRequestData.dialogueText
      value: "\u3042\u306F\u306F\uFF01\u3053\u308C\u306F\u30CD\u30BA\u30DF\u306E\u5730\u4F4D\u5411\u4E0A\u306B\u5F79\u7ACB\u3064\u3060\u308D\u3046\u306A\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30533030561448297].talkRequestData.dialogueText
