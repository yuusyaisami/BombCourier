      value: "\u30E4\u30AF\u30E2\u304C\u3084\u3063\u3066\u308B\u6D3B\u52D5\u3082\u3001\n\u591A\u304F\u306E\u4EBA\u306E\u751F\u6D3B\u3092\u3088\u308A\u3088\u304F\u3059\u308B\u3082\u306E\u3060"
