    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031543439957].talkRequestData.dialogueText
      value: "\u3042\u3089\u3001\u3053\u3093\u306A\u3068\u3053\u308D\u3067\u30CD\u30BA\u30DF\u306B\u5408\u3046\u306A\u3093\u3066\u73CD\u3057\u3044\u308F!"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031543440238].talkRequestData.dialogueText
      value: "\u3053\u306E\u30BF\u30EF\u30FC\u306B\u8FD1\u3065\u304F\u306E\u306F\n\u7981\u6B62\u306B\u3055\u308C\u3066\u308B\u3093\u3058\u3083\u306A\u304B\u3063\u305F\u3063\u3051"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031565197377].talkRequestData.dialogueText
      value: "\u307E\u3042\u3001\u4E00\u822C\u7684\u306B\u306F\u3001\u826F\u304F\u306A\u3044\u3063\u3066\u8A00\u308F\u308C\u3066\u3044\u308B\u308F\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031565197518].talkRequestData.dialogueText
      value: "\u7981\u65AD\u306E\u679C\u5B9F\u307F\u305F\u3044\u306A\u3082\u306E\u3088,
        \u79C1\u306B\u3068\u3063\u3066\u306F\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031565197659].talkRequestData.dialogueText
      value: "\u3053\u3053\u306F\u306D\u3001\u795E\u69D8\u306E\u76E3\u8996\u5854\u3063\u3066\u8A00\u308F\u308C\u3066\u3044\u308B\u306E"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031565197870].talkRequestData.dialogueText
      value: "\u3058\u3083\u3042\u3042\u305D\u3053\u306B\u3001\u5642\u306E\u795E\u69D8\u304C\uFF01\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031565198011].talkRequestData.dialogueText
      value: "\u3055\u3042\u3001\u5411\u3053\u3046\u304B\u3089\u306F\u898B\u3048\u3066\u308B\u3063\u3066\u5642\u3060\u3051\u3069\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031584596065].talkRequestData.dialogueText
      value: "\u305D\u3046\u306D\u3001\u60AA\u3044\u3053\u3068\u3070\u304B\u308A\u3057\u3066\u304D\u305F\u3057\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031584596206].talkRequestData.dialogueText
      value: "\u4ECA\u9803\u3001\u4F55\u3092\u3057\u3066\u3082\u3001\u5929\u7F70\u304C\u4E0B\u308B\u3053\u3068\u306B\u9593\u9055\u3044\u306F\u306A\u3044\u308F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031584596347].talkRequestData.dialogueText
      value: "\u3067\u3082\u3001\u4ECA\u306F\u697D\u3057\u3044\u3057\u3001\n\u3084\u308A\u305F\u3044\u3053\u3068\u3082\u3084\u308C\u3066\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031584596628].talkRequestData.dialogueText
      value: "\u305D\u308C\u3063\u3066\u3064\u307E\u308A\u3001\u5E78\u305B\u3063\u3066\u3053\u3068\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031584596769].talkRequestData.dialogueText
      value: "...\u305D\u3046\u306A\u306E\u304B\u306A"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031601897530].talkRequestData.dialogueText
      value: "\u8FF7\u3063\u3066\u3044\u308B\u306E\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031601897671].talkRequestData.dialogueText
      value: "\u3042\u306F\u306F\uFF01\u6DF1\u523B\u306A\u308F\u3051\u3058\u3083\u306A\u3044\u308F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031601897812].talkRequestData.dialogueText
      value: "\u5C11\u3057\u3060\u3051\u3088\u3001\u5C11\u3057\u3060\u3051"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031601898023].talkRequestData.dialogueText
      value: "\u82B8\u8853\u5BB6\u306A\u3089\u3001\u305D\u306E\u8FF7\u3044\u3055\u3048\u3082\u4F5C\u54C1\u306B\u843D\u3068\u3057\u8FBC\u3080\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031601898164].talkRequestData.dialogueText
      value: "\u305D\u306E\u3050\u3089\u3044\u306E\u56F3\u592A\u3055\u304C\u306A\u3051\u308C\u3070\u3001\u8FF7\u3044\u306F\u65AD\u3061\u5207\u308C\u306A\u3044\u308F\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031601898375].talkRequestData.dialogueText
      value: "\u3048\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031618674708].talkRequestData.dialogueText
      value: "\u3046\u3093\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031618674919].talkRequestData.dialogueText
      value: "\u305D\u3046...\u3042\u306A\u305F\u306F\u79C1\u4EE5\u4E0A\u306B\u82B8\u8853\u5BB6\u3067"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031618675060].talkRequestData.dialogueText
      value: "\u30E4\u30AF\u30E2\u4EE5\u4E0A\u306B\u79D1\u5B66\u8005\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031618675201].talkRequestData.dialogueText
      value: "\u50D5\u306F\u50D5\u3001\u305D\u308C\u4EE5\u4E0A\u3082\u305D\u308C\u4EE5\u4E0B\u3082\u306A\u3044\u3088"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031618675482].talkRequestData.dialogueText
      value: "\u3042\u3089\u3001\u9762\u767D\u3044\u3053\u3068\u3092\u3044\u3046\u306E\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031618675623].talkRequestData.dialogueText
      value: ...
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031677394996].talkRequestData.dialogueText
      value: "\u6B63\u76F4\u306A\u3068\u3053\u308D \u3042\u305D\u3053\u306B\u4F55\u304C\u3042\u308B\u306E\u304B\u3001\u8AB0\u3082\u77E5\u3089\u306A\u3044"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031677395207].talkRequestData.dialogueText
      value: "\u307F\u3093\u306A\u8FD1\u5BC4\u3089\u306A\u3044\u3093\u3060\u3088\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031677395348].talkRequestData.dialogueText
      value: "\u3048\u3048\u3001\u3042\u306A\u305F\u304C\u3001\u305D\u306E\u98A8\u7A74\u3092\u958B\u3051\u305F\u3089\u3001\n\u79C1\u3082\u884C\u3053\u3046\u304B\u3057\u3089\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533031677395489].talkRequestData.dialogueText
