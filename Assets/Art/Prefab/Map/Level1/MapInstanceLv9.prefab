    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533030743638495].talkRequestData.dialogueText
      value: "\u3084\u3042\u3001\u30CD\u30BA\u30DF\u3055\u3093"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533030743638704].talkRequestData.dialogueText
      value: "\u3053\u3093\u306A\u3068\u3053\u308D\u3067\u4F55\u3092\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533030743638809].talkRequestData.dialogueText
      value: "\u3053\u306E\u7D75\u3092\u898B\u3066\u3044\u305F\u3093\u3060\u3088\u3002\n\u7206\u5F3E\u3092\u8D77\u7206\u3057\u3066\u3057\u307E\u3063\u305F\u3001\u308F\u3093\u3053\u306E\u7D75\u3060\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533030743639018].talkRequestData.dialogueText
      value: "\u3053\u3053\u3067\u306F\u3088\u304F\u3001\u5148\u3092\u898B\u305A\u3001\n\u7206\u5F3E\u3092\u8D77\u52D5\u3055\u305B\u3066\u3057\u307E\u3046\u4EBA\u304C\u3044\u308B\u304B\u3089\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072890963].talkRequestData.dialogueText
      value: "\u3060\u304B\u3089\u591A\u304F\u306E\u4EBA\u305F\u3061\u306F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072891172].talkRequestData.dialogueText
      value: "\u5C11\u3057\u306E\u3053\u3068\u3067\u3001\u5927\u3051\u304C\u3092\u3059\u308B\u304B\u3082\u3057\u308C\u306A\u3044\n\u3053\u3053\u306F\u5371\u967A\u3060"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072891277].talkRequestData.dialogueText
      value: "\u305D\u3046\u3060\u3001\u79C1\u305F\u3061\u3082\u57FA\u672C\u306F\u5B89\u5168\u306A\u533A\u753B\u3067\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072891486].talkRequestData.dialogueText
      value: "\u541B\u3082\u305D\u3046\u3060\u308D\u3046\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072891591].talkRequestData.dialogueText
      value: "\u5197\u8AC7\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072891748].talkRequestData.dialogueText
      value: "...\u5916\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031072891853].talkRequestData.dialogueText
      value: "(\u3057\u307E\u3063\u305F\u3001\u7981\u53E5\u3060\u3063\u305F)"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117455414].talkRequestData.dialogueText
      value: "\u79C1\u3082\u3001\u6614\u306F\u5916\u306B\u3044\u305F\u3088\u3001\u541B\u3068\u540C\u3058\u3067"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117455519].talkRequestData.dialogueText
      value: "\u79C1\u3082\u3001\u6614\u306F\u5916\u306B\u3044\u305F\u3088\u3001\u541B\u3068\u540C\u3058\u3067"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117455624].talkRequestData.dialogueText
      value: "?! \u305D\u3046\u306A\u3093\u3067\u3059\u304B"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117455729].talkRequestData.dialogueText
      value: "\u3042\u3042\u3002\u3060\u304C\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117455834].talkRequestData.dialogueText
      value: "\u5FD8\u308C\u3082\u3057\u306A\u3044\u3001\u3042\u308C\u306F\u51B7\u305F\u3044\u91D1\u5C5E\u306E\u30B1\u30FC\u30B8\u306E\u4E2D\u3060\u3063\u305F\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117455939].talkRequestData.dialogueText
      value: "\u8997\u304D\u3053\u3080\u5927\u304D\u306A\u76EE\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117456148].talkRequestData.dialogueText
      value: "\u305D\u3057\u3066\u3001\u4E0D\u601D\u8B70\u306A\u8272\u306E\u98DF\u3079\u7269\u3092\n\u4F55\u5EA6\u3082\u98F2\u307E\u3055\u308C\u3066\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117456253].talkRequestData.dialogueText
      value: "\u6C17\u3065\u3044\u305F\u3089\u3001\u3053\u306E\u4E16\u754C\u306B\u843D\u3068\u3055\u308C\u3066\u3044\u305F\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031117456358].talkRequestData.dialogueText
      value: "\u305A\u3063\u3068\u6614\u306E\u8A71\u3060\u304C\u3001\u3042\u306E\u6642\u306E\u6050\u6016\u306F\u9AA8\u306E\u9AC4\u307E\u3067\u67D3\u307F\u4ED8\u3044\u3066\u3044\u308B\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031140786255].talkRequestData.dialogueText
      value: "\u541B\u306B\u3068\u3063\u3066\u5916\u306F\u3001\u5E30\u308B\u5834\u6240\u306A\u306E\u304B\u3082\u3057\u308C\u306A\u3044\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031140786360].talkRequestData.dialogueText
      value: "\u3060\u304C\u3001\u79C1\u306B\u3068\u3063\u3066\u306F\u3001\u623B\u308A\u305F\u304F\u306A\u3044\u5834\u6240\u3060\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: c2a9174ac64033d448a5ee0496baaf3d, type: 3}
      propertyPath: managedReferences[30533031140786830].talkRequestData.dialogueText
      value: "\u306A\u3093\u3060\u3063\u3066\uFF1F"
      objectReference: {fileID: 0}
