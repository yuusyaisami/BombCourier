      value: "\u304D\u306E\u3053\u306F\u30B5\u30D6\u30EC\u30AF\u30C3\u30B7\u30E7\u30F3\u3068\u9055\u3063\u3066\u3001\u8DF3\u306D\u308B\u304B\u3089\u306D\u3001\n\u9AD8\u3044\u3068\u3053\u308D\u306B\u884C\u304D\u305F\u3044\u5834\u5408\u306B\u306F\u3046\u3063\u3066\u3064\u3051\u3060\u3088\u3002"
