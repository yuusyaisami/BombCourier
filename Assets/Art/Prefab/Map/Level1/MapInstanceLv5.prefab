      propertyPath: managedReferences[30532896011846524].talkRequestData.dialogueText
      value: "\u3069\u3001\u3069\u3046\u3082..."
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532896011846525].talkRequestData.dialogueText
      value: "\u5927\u4E08\u592B\u3060\u3088\u3001\u53D6\u3063\u3066\u98DF\u3063\u305F\u308A\u3057\u306A\u3044\u3055\n\u5C11\u306A\u304F\u3068\u3082\u4ECA\u306F\u306D"
