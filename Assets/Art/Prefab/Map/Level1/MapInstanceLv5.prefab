    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344427135].talkRequestData.dialogueText
      value: "(\u306D\u3053\u3060\uFF01\u5371\u967A\u306A\u9999\u308A\u304C\u3059\u308B)"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344427341].talkRequestData.dialogueText
      value: "\u3069\u3046\u3082"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344427465].talkRequestData.dialogueText
      value: "\u3069\u3001\u3069\u3046\u3082..."
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344427589].talkRequestData.dialogueText
      value: "\u5927\u4E08\u592B\u3060\u3088\u3001\u53D6\u3063\u3066\u98DF\u3063\u305F\u308A\u3057\u306A\u3044\u3055\n\u5C11\u306A\u304F\u3068\u3082\u4ECA\u306F\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344427713].talkRequestData.dialogueText
      value: "\uFF01\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344427837].talkRequestData.dialogueText
      value: "\u3068\u3053\u308D\u3067\u541B\u306F\u3053\u3093\u306A\u3068\u3053\u308D\u3067\u4F55\u3092\u3084\u3063\u3066\u308B\u3093\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895344428002].talkRequestData.dialogueText
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895561220355].talkRequestData.dialogueText
      value: "\u3061\u306A\u307F\u306B\u50D5\u306F\u3044\u307E\u3001\u3053\u306E\u3067\u304B\u3044\u5207\u308A\u682A\u3092\u8ABF\u3079\u3066\u3044\u308B\u3093\u3060"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895561220479].talkRequestData.dialogueText
      value: "\u3053\u3093\u306A\u8CEA\u7D20\u306A\u5834\u6240\u306B\u3001\u6728\u304C\u751F\u3048\u3066\u3044\u305F\u306A\u3093\u3066\u3001\u4FE1\u3058\u3089\u308C\u306A\u3044\u3088\uFF01\n\u79D1\u5B66\u8005\u3068\u3057\u3066\u306F\u3001\u6700\u9AD8\u306E\u30B5\u30F3\u30D7\u30EB\u3060"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895561220726].talkRequestData.dialogueText
      value: "\u629C\u3051\u51FA\u3059...?\n\u305D\u308C\u306F\u96E3\u3057\u3044\u304B\u3082\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895561220891].talkRequestData.dialogueText
      value: "\u591A\u304F\u306E\u8ABF\u67FB\u968A\u304C\u884C\u3051\u308B\u5834\u6240\u306F\u5168\u90E8\u8ABF\u3079\u305F\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895561221056].talkRequestData.dialogueText
      value: "\u3057\u304B\u3057\uFF01\u6B8B\u5FF5\u306A\u304C\u3089\u51FA\u53E3\u3089\u3057\u304D\u3082\u306E\u306F\u898B\u3064\u304B\u3089\u306A\u304B\u3063\u305F\u306E\u3060"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895646154935].talkRequestData.dialogueText
      value: "\u7D50\u679C\u7684\u306B\u50D5\u305F\u3061\u306F\u5C0F\u3055\u306A\u30B3\u30DF\u30E5\u30CB\u30C6\u30A3\u30FC\u3092\u5F62\u6210\u3057\u3066\u3001\n\u4ECA\u307E\u3067\u751F\u304D\u5EF6\u3073\u3066\u308B\u3093\u3060\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895646155182].talkRequestData.dialogueText
      value: "\u306A\u308B\u307B\u3069... \u5B9A\u671F\u7684\u306B\u65B0\u4EBA\u304C\u9001\u3089\u308C\u3066\u304F\u308B\u3068\u306F\u805E\u3044\u3066\u3044\u305F\u304C\u3001\n\u3069\u3046\u3084\u3089\u541B\u306F\u305D\u308C\u306B\u8A72\u5F53\u3059\u308B\u3088\u3046\u3060\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895646155347].talkRequestData.dialogueText
      value: "\u305D\u306E\u611F\u3058\u3060\u3068\u3001\u521D\u3081\u3066\u4F1A\u3046\u306E\u306F\u50D5\u3063\u3066\u611F\u3058\u304B\u306A...?"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895646155471].talkRequestData.dialogueText
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895738429506].talkRequestData.dialogueText
      value: "...\u3042\u3042\u3054\u3081\u3093\u3001\u6C17\u9063\u3044\u304C\u3067\u304D\u3066\u3044\u306A\u304B\u3063\u305F\u3002\u7533\u3057\u8A33\u306A\u3044"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895738429548].talkRequestData.dialogueText
      value: "\u3042\u306F\u306F\uFF01\u305D\u306E\u901A\u308A\uFF01\n\u3067\u3082\u4ECA\u306F\u8A71\u304C\u5909\u308F\u3063\u3066\u3001\u50D5\u305F\u3061\u306F\u98DF\u3079\u308C\u306A\u3044\u3093\u3060\u3001\u306D\u305A\u307F\u3092"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895738429672].talkRequestData.dialogueText
      value: "\u524D\u306B\u3082\u8A71\u3057\u305F\u3088\u3046\u306B\u3001\u50D5\u305F\u3061\u306F\u5C0F\u3055\u306A\u30B3\u30DF\u30E5\u30CB\u30C6\u30A3\u30FC\u3092\u5F62\u6210\u3057\u3066\u3044\u308B\u3002\n\u305D\u3053\u3067\u306F\u3001\u3044\u304F\u3064\u304B\u30EB\u30FC\u30EB\u3001\u3064\u307E\u308A\u306F\u6CD5\u5F8B\u304C\u3042\u308B\u3093\u3060"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895738429837].talkRequestData.dialogueText
      value: "\u305D\u306E\u306A\u304B\u306B\u306F\u3001\u30D7\u30EC\u30C7\u30BF\u30FC\u306F\u5373\u9996\u540A\u308A\u3063\u3066\u6CD5\u5F8B\u304C\u3042\u308B\u3093\u3060...\n\u3068\u307B\u307B..."
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895738429961].talkRequestData.dialogueText
      value: (...)
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895738430415].talkRequestData.dialogueText
      value: "\u3042\u3042\uFF01\u30D0\u30CB\u30E9\u306E\u3053\u3068\u304B\u306A\uFF1F\n\u305D\u308C\u306F\u3068\u3093\u3060\u707D\u96E3\u3060\u3063\u305F\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: 147bc05705431df44adfc159ffde4a0b, type: 3}
      propertyPath: managedReferences[30532895846432802].talkRequestData.dialogueText
      value: "\u3042\u3042\uFF01\u30D0\u30CB\u30E9\u306E\u3053\u3068\u304B\u306A\uFF1F\n\u305D\u308C\u306F\u3068\u3093\u3060\u707D\u96E3\u3060\u3063\u305F\u306D"
      objectReference: {fileID: 0}
