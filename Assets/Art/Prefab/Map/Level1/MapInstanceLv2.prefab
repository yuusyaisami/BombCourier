    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340237].talkRequestData.dialogueText
      value: "\u3053\u3093\u306B\u3061\u306F\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340239].talkRequestData.dialogueText
      value: "\u79C1\u306F\u306D\u3001\u6C7A\u5B9A\u7684\u77AC\u9593\u3092\u5207\u308A\u53D6\u3063\u3066\u3001\n\u7D75\u306B\u3057\u3066\u98FE\u3063\u3066\u3044\u308B\u306E\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340240].talkRequestData.dialogueText
      value: "\u6C7A\u5B9A\u7684\u306A\u77AC\u9593\u3001\u305D\u308C\u306F\u5931\u6557\u306E\u77AC\u9593\u3088!"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340241].talkRequestData.dialogueText
      value: "(\u3084\u3070\u3044\u5974\u3060...\u82B8\u8853\u5BB6\u306E\u76AE\u3092\u88AB\u3063\u305F\u305F\u3060\u306E\u30B5\u30C7\u30A3\u30B9\u30C8\u3060\uFF09"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340242].talkRequestData.dialogueText
      value: "\u305D\u3046\u306D\u3047...\u6B21\u306B\u3042\u306A\u305F\u306F\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340243].talkRequestData.dialogueText
      value: "(\u9055\u3063\u305F\uFF01\u5371\u967A\u3092\u77E5\u3089\u305B\u3066\u304F\u308C\u308B\u512A\u3057\u3044\u4EBA\u3060\uFF01)"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340244].talkRequestData.dialogueText
      value: "\u3044\u3044\u3053\u3068\uFF1F \u79C1\u306E\u30A4\u30F3\u30B9\u30D4\u30EC\u30FC\u30B7\u30E7\u30F3\u306E\u305F\u3081\u306B\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340245].talkRequestData.dialogueText
      value: "\uFF08\u9055\u3063\u305F\uFF01 \u3084\u3063\u3071\u308A\u305F\u3060\u306E\u3084\u3070\u3044\u5974\u3060\uFF01\uFF09"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340246].talkRequestData.dialogueText
      value: "\u3044\u3044\uFF01\uFF1F \u7D76\u5BFE\u306B\u3001\n\u79C1\u306E\u96A3\u306B\u3042\u308B\u3053\u306E\u30B5\u30D6\u30EC\u30AF\u30C3\u30B7\u30E7\u30F3\u3092\u6301\u3061\u904B\u3093\u3067\u3001"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340247].talkRequestData.dialogueText
      value: "\u30AF\u30C3\u30B7\u30E7\u30F3\u306E\u67D4\u3089\u304B\u3055\u3067\u52A9\u304B\u308D\u3046\u3068\u3059\u308B\u306A\u3093\u3066\u3001\n\u79C1\u306E\u82B8\u8853\u3078\u306E\u5192\u6D9C\u3060\u304B\u3089\u306D\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340248].talkRequestData.dialogueText
      value: "\uFF08\u306A\u308B\u307B\u3069\uFF01 \u3042\u306E\u30AF\u30C3\u30B7\u30E7\u30F3\u3092\u6301\u3063\u3066\u98DB\u3073\u964D\u308A\u3066\u3001\n\u305D\u306E\u4E0A\u306B\u7740\u5730\u3059\u308C\u3070\u7206\u767A\u305B\u305A\u306B\u6E08\u3080\u306E\u304B\uFF09"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340249].talkRequestData.dialogueText
      value: "\u3042\u308A\u304C\u3068\u3046\uFF01\u53C2\u8003\u306B\u3059\u308B\u306D\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340250].talkRequestData.dialogueText
      value: "\u3048\u3048\uFF01\u3059\u3079\u3066\u306E\u751F\u7269\u306F\u82B8\u8853\u5BB6\u3088"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340252].talkRequestData.dialogueText
      value: "\u8A00\u308F\u305A\u3082\u304C\u306A\u3001\u82B8\u8853\u5BB6\u306E\u30D0\u30CB\u30E9\u3088\uFF01\u3046\u3093\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340253].talkRequestData.dialogueText
      value: "(\u8A00\u308F\u305A\u3082\u304C\u306A...?)"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340254].talkRequestData.dialogueText
      value: "\u3053\u3053\u306F\u79C1\u306E\u30A2\u30C8\u30EA\u30A8\u3088\uFF01\n"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532875499340255].talkRequestData.dialogueText
      value: "(\u305D\u3046\u3060\u3063\u305F\u306E\u304B)"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30532954408354182].talkRequestData.dialogueText
      value: "\uFF1F\u3063\u3066\u9854\u306D"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533001124511829].talkRequestData.dialogueText
      value: "\u3053\u308C\u306F\u547D\u4EE4\u3088\u3001\u7D76\u5BFE\u3060\u304B\u3089\u306D\uFF01"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533034660856518].talkRequestData.dialogueText
      value: "\u305D\u3057\u3066\u843D\u4E0B\u306E\u885D\u6483\u3067\u30C9\u30AB\u30F3\uFF01
        \u3063\u3066\u7206\u6B7B"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
