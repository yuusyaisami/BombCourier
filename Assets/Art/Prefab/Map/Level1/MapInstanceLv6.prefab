      value: "\u300C\u9905\u306F\u9905\u5C4B\u300D\u306A\u3089\u3001\n\u30A6\u30B5\u30AE\u306E\u3053\u3068\u306F\u30A6\u30B5\u30AE\u306B\u805E\u304F\u306E\u304C\u6B63\u89E3\u3058\u3083\u306A\u3044\uFF1F"
