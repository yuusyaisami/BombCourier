    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583072].talkRequestData.dialogueText
      value: "\u3042\u306A\u305F\u3001\u8AB0\u306B\u3067\u3082\u305D\u3093\u306A\u3053\u3068\u805E\u3044\u3066\u56DE\u3063\u3066\u3044\u308B\u306E\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583073].talkRequestData.dialogueText
      value: "\u3046\u3093\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583074].talkRequestData.dialogueText
      value: "\u3060\u3063\u305F\u3089\u3084\u3081\u305F\u65B9\u304C\u3044\u3044\u308F\u3002\n\u305D\u308C\u3001\u3053\u306E\u4E16\u754C\u3058\u3083\u3081\u3061\u3083\u304F\u3061\u3083\u306A\u7981\u53E5\u3088\uFF1F"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583075].talkRequestData.dialogueText
      value: "\u307F\u3093\u306A\u3001\u898B\u305F\u304F\u306A\u3044\u7D75\u3092\u898B\u308B\u307F\u305F\u3044\u306A\u9854\u3092\u3059\u308B\u304B\u3089\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583076].talkRequestData.dialogueText
      value: "(\u5B89\u6613\u306B\u60F3\u50CF\u304C\u3064\u304F)"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583077].talkRequestData.dialogueText
      value: "\u3044\u3044\u306E\u3088\u3002\u82B8\u8853\u5BB6\u306F\u50B7\u3064\u304D\u3084\u3059\u3044\u3082\u306E\u3060\u304B\u3089\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583122].talkRequestData.dialogueText
      value: "\u5916\u2026\u2026\uFF1F \u3042\u3042\u3001\u78BA\u304B\u79C1\u306E\u4E21\u89AA\u304C\u2026\u2026\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583123].talkRequestData.dialogueText
      value: "\u3044\u3084\u3001\u306A\u3093\u3067\u3082\u306A\u3044\u308F\uFF01
        \n\u77E5\u3089\u306A\u3044\u308F\u3088\u3001\u5916\u306A\u3093\u3066\u3002"
      objectReference: {fileID: 0}
    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029247583124].talkRequestData.dialogueText
      value: "\uFF08\u308F\u304B\u308A\u3084\u3059\u3044\u53CD\u5FDC\u3060\u306A\uFF09"
