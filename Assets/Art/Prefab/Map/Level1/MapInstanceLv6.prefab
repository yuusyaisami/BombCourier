    - target: {fileID: 1302941564186950030, guid: d363be833c43a174582360160d17b393, type: 3}
      propertyPath: managedReferences[30533029998887010].talkRequestData.dialogueText
      value: "\u3042\u308C\u3001\u3055\u3063\u304D\u306E\u4F1A\u8A71\u3063\u3066\u3082\u3046\u4E00\u56DE\u3067\u304D\u306A\u3044\u306E\uFF1F"
